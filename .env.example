# Optional: override defaults. The app runs without this file.
# Copy to .env and edit as needed.

# Platform API (tasks, sessions, gamification)
API_URL=http://localhost:5000/api

# Cyrex AI (classification, challenges, RAG)
AI_SERVICE_URL=http://localhost:8000

# Cyrex web UI (embedded in the "Cyrex" tab)
CYREX_INTERFACE_URL=http://localhost:5175

# Helox pipelines (path to diri-helox repo)
# HELOX_PATH=/path/to/deepiri-platform/diri-helox

# API key sent to backend (if required)
# PYAGENT_API_KEY=your_api_key_here
